
// EE-008: if is the last statement of the action but not all branches exit.
task class foo {

    snk : sink u32 triggers action0;

    out_prt : out u32;

    action action1(&priv self, data : u32) -> Status<i32> {

        var st : Status<i32> = Success;

        return st;

    }

    action action0(&priv self, data : u32) -> Status<i32> {

        if (data == 0) {

            continue self->action1(data);

        } else {

            self->out_prt.send(data);

        }

    }

};
