

function foo(data : &mut u32, adder : u32) {

    *data = *data + adder;

    return;

}



task class TaskClass {

    field0 : u32;

    port0 : in u32 triggers action0;

    action action0(&priv self, input : u32) -> Status<i32> {


        var ret : Status<i32> = Success;

        foo(&mut self->field0, input);

        return ret;


    }
    


};
