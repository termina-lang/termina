interface Interface0 {

    procedure proc0(&mut self, input : u32);

};

resource class ResourceClass0 provides Interface0 {

    field0 : u32;

    procedure proc0(&mut self, input : u32) {

       self->field0 = input; 
       return;

    }

};

task class TaskClass0 {

    field0 : u32;

    snk0 : sink TimeVal triggers action0;

    action action0(&priv self, input : TimeVal) -> Status<i32> {

        var ret : Status<i32> = Success;

        self->field0 = input.tv_sec;

        return ret;

    }

};

resource res0 : ResourceClass0 = { field0 = 0 };
emitter timer0 : PeriodicTimer = {
    period = {tv_sec = 1 : u32, tv_usec = 0 : u32}
};
emitter timer1 : PeriodicTimer = {
    period = {tv_sec = 1 : u32, tv_usec = 0 : u32}
};
task task0 : TaskClass0 = { field0 <- timer0, snk0 <- timer1 };
