
interface Interface0 {

    procedure proc0(&mut self, input : u32);

};

resource class Resource0 provides Interface0 {

    field0 : u32;

    procedure proc0(&mut self, input : u32) {

        self->field0 = input;

    }

};

task class TaskClass0 {

    ap0 : access Interface0;

    field0 : u32;

    snk0 : sink u32 triggers action0;

    viewer viewer0(&self, value : u32) -> bool {

        return value == self->field0;

    }

    action action0(&priv self, input : u32) -> Status<i32> {

        var ret : Status<i32> = Success;

        continue self->viewer0(input);

    }


};
