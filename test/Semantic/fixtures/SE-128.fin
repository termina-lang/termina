interface IFoo {
    procedure get(&mut self, r : &mut u32);
};

resource class FooRes provides IFoo {

    value : u32;

    method aux(&mut self) {
        self->get(&mut self->value);
        return;
    }

    procedure get(&mut self, r : &mut u32) {
        *r = self->value;
        return;
    }

};
