interface IFoo {
    procedure get(&mut self, r : &mut u32);
};

resource class FooRes provides IFoo {

    value : u32;

    method m0(&mut self) {
        self->m1();
        return;
    }

    method m1(&mut self) {
        self->m0();
        return;
    }

    procedure get(&mut self, r : &mut u32) {
        *r = self->value;
        return;
    }

};
