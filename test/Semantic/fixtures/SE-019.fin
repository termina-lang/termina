interface TMChannelInterface {

    procedure get_tm_packets(&mut self, packets : u32);

};

resource class TMChannel provides TMChannelInterface {
    
  tm_sent_packets : u32;

  procedure get_tm_sent_packets(&mut self, packets : &mut u32) {

    *packets = self->tm_sent_packets;

    return;

  }

  procedure get_tm_packets(&mut self, packets : u32) {

    self->tm_sent_packets = packets;

    return;

  }

};
